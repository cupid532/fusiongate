# Generate with: openssl rand -base64 32
FUSIONGATE_MASTER_KEY=replace_with_32_byte_base64_key
# Use a unique high-entropy password. It is PBKDF2-HMAC-SHA256 hashed at first boot.
FUSIONGATE_ADMIN_PASSWORD=replace_with_a_long_unique_password
# Production deployments may set FUSIONGATE_MASTER_KEY_FILE and
# FUSIONGATE_ADMIN_PASSWORD_FILE instead of placing secrets in the environment.
# Safe default: bind admin + API gateway to localhost. Put Caddy/Nginx/VPN in front if remotely accessed.
FUSIONGATE_ADDR=127.0.0.1:8787
FUSIONGATE_DATA_DIR=./data
# Development-only opt-ins. Do not enable for a public deployment.
# FUSIONGATE_ALLOW_INSECURE_UPSTREAMS=false
# FUSIONGATE_ALLOW_PRIVATE_UPSTREAMS=false
